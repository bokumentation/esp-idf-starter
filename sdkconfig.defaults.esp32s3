# Config for ESP32S3 with 8MB flash size
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="extras/partitions-8mb.csv"
CONFIG_PARTITION_TABLE_FILENAME="extras/partitions-8mb.csv"

